rules_version = '2';

// Paste this into Firebase Console -> Firestore Database -> Rules -> Publish.
// (Project: vawakeningcom)
//
// Public content (blogs, programs, resources, store_products) is readable by
// anyone, since it's shown on the public website. Writes are restricted to
// signed-in Firebase Auth users only -- i.e. whoever you create as an admin
// user under Authentication -> Users, since there is no public sign-up flow.
//
// product_stock_notifications is written by anonymous site visitors (the
// "Notify Me" form), so it allows public create but not public read/update/
// delete, to avoid leaking other customers' emails.

service cloud.firestore {
  match /databases/{database}/documents {

    match /blogs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /resources/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /store_products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /product_stock_notifications/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}
